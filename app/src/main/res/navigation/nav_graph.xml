<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dashboard">

    <fragment android:id="@+id/dashboard"
        android:name="com.personal.financetracker.ui.dashboard.DashboardFragment"
        android:label="Home">
        <action android:id="@+id/action_dashboard_to_add"
            app:destination="@id/addTransaction"
            app:enterAnim="@anim/slide_up"
            app:exitAnim="@anim/fade_out"
            app:popEnterAnim="@anim/fade_in"
            app:popExitAnim="@anim/slide_down"/>
    </fragment>

    <fragment android:id="@+id/transactions"
        android:name="com.personal.financetracker.ui.transactions.TransactionsFragment"
        android:label="Transactions">
        <action android:id="@+id/action_transactions_to_add"
            app:destination="@id/addTransaction"
            app:enterAnim="@anim/slide_up"
            app:exitAnim="@anim/fade_out"
            app:popEnterAnim="@anim/fade_in"
            app:popExitAnim="@anim/slide_down"/>
    </fragment>

    <fragment android:id="@+id/reports"
        android:name="com.personal.financetracker.ui.reports.ReportsFragment"
        android:label="Reports"/>

    <fragment android:id="@+id/planned"
        android:name="com.personal.financetracker.ui.planned.PlannedFragment"
        android:label="Planned"/>

    <fragment android:id="@+id/categories"
        android:name="com.personal.financetracker.ui.categories.CategoriesFragment"
        android:label="Categories"/>

    <fragment android:id="@+id/addTransaction"
        android:name="com.personal.financetracker.ui.add.AddTransactionFragment"
        android:label="Add Transaction">
        <argument
            android:name="transactionId"
            app:argType="long"
            android:defaultValue="0L" />
    </fragment>

</navigation>

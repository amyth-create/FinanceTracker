<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="18dp"
    android:paddingBottom="6dp"
    android:paddingHorizontal="4dp">

    <TextView android:id="@+id/tv_date"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/text_secondary" android:textSize="12sp" android:textStyle="bold"/>

    <TextView android:id="@+id/tv_total"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="@color/text_muted" android:textSize="12sp" android:textStyle="bold"/>
</LinearLayout>

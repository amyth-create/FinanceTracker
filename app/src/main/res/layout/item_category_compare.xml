<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="7dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical">

        <TextView android:id="@+id/tv_emoji"
            android:layout_width="40dp" android:layout_height="40dp"
            android:gravity="center" android:textSize="18sp"
            android:background="@drawable/rounded_rect"
            android:layout_marginEnd="10dp"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">

            <TextView android:id="@+id/tv_name"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="@color/text_primary" android:textSize="13sp"
                android:textStyle="bold" android:layout_marginBottom="6dp"/>

            <!-- Month A bar -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <View android:layout_width="6dp" android:layout_height="6dp"
                    android:background="@color/accent" android:layout_marginEnd="6dp"/>
                <FrameLayout android:id="@+id/bar_track_a"
                    android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1">
                    <View android:id="@+id/view_bar_a"
                        android:layout_width="0dp" android:layout_height="6dp"
                        android:background="@color/accent"/>
                </FrameLayout>
                <TextView android:id="@+id/tv_amount_a"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="8dp" android:minWidth="64dp" android:gravity="end"
                    android:textColor="@color/text_primary" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- Month B bar -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <View android:layout_width="6dp" android:layout_height="6dp"
                    android:background="@color/text_secondary" android:layout_marginEnd="6dp"/>
                <FrameLayout android:id="@+id/bar_track_b"
                    android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1">
                    <View android:id="@+id/view_bar_b"
                        android:layout_width="0dp" android:layout_height="6dp"
                        android:background="@color/text_secondary"/>
                </FrameLayout>
                <TextView android:id="@+id/tv_amount_b"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="8dp" android:minWidth="64dp" android:gravity="end"
                    android:textColor="@color/text_secondary" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <TextView android:id="@+id/tv_delta"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="10dp" android:minWidth="58dp" android:gravity="end"
            android:textSize="12sp" android:textStyle="bold"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
